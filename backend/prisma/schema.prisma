// Prisma schema for Product Catalog
// Database: PostgreSQL
// Purpose: Efficient cursor-based pagination for 200,000 products
//
// Index strategy:
// 1. idx_products_updated_at_id (updatedAt DESC, id DESC)
//    - Powers cursor pagination ORDER BY updated_at DESC, id DESC.
//    - Composite (updatedAt + id) ensures deterministic ordering when timestamps collide.
//    - Without id tiebreaker, products with same updated_at would have undefined order.
//
// 2. idx_products_category_updated_at_id (category, updatedAt DESC, id DESC)
//    - Powers filtered pagination: WHERE category = ? ORDER BY updated_at DESC, id DESC.
//    - Category as leading column lets PostgreSQL seek directly to category in B-tree.
//    - Without this index, filtered queries would do sequential scan + sort (slow at 200k rows).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  category  String   @db.VarChar(100)
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([updatedAt(desc), id(desc)], name: "idx_products_updated_at_id")
  @@index([category, updatedAt(desc), id(desc)], name: "idx_products_category_updated_at_id")
  @@map("products")
}
